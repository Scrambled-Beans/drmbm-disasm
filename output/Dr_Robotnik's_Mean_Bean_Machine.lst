00000000 =00000003                  bit_R:		equ 3				; Right
00000000 =00000004                  bit_B:		equ 4				; B
00000000 =00000005                  bit_C:		equ 5				; C 
00000000 =00000006                  bit_A:		equ 6				; A
00000000 =00000007                  bit_S:		equ 7				; START
00000000                            
00000000 =00000001                  btn_U:		equ 1<<bit_U		; ($01)
00000000 =00000002                  btn_D:		equ 1<<bit_D		; ($02)
00000000 =00000004                  btn_L:		equ 1<<bit_L		; ($04)
00000000 =00000008                  btn_R:		equ 1<<bit_R		; ($08)
00000000 =00000010                  btn_B:		equ 1<<bit_B		; ($10)
00000000 =00000020                  btn_C:		equ 1<<bit_C		; ($20)
00000000 =00000040                  btn_A:		equ 1<<bit_A		; ($40)
00000000 =00000080                  btn_S:		equ 1<<bit_S		; ($80)
00000000                            
00000000                            btn_Dir:	equ btnUp|btnDn|btnL|btnR	; ($0F)
00000000                            btn_ABC:	equ btnA|btnB|btnC			; ($70)
