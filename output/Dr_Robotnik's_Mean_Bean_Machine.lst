00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set FM instrument feedback register and store instrument data
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	fb	- Feedback value
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cfiFeedback macro fb
00000000                            
00000000                            cfiFB		= fb
00000000                            
00000000                            	dc.b	(cfiDT1<<4)|cfiMULT1, (cfiDT2<<4)|cfiMULT2, (cfiDT3<<4)|cfiMULT3, (cfiDT4<<4)|cfiMULT4
00000000                            	dc.b	cfiTL1, cfiTL2, cfiTL3, cfiTL4
00000000                            	dc.b	(cfiRS1<<6)|cfiAR1, (cfiRS2<<6)|cfiAR2, (cfiRS3<<6)|cfiAR3, (cfiRS4<<6)|cfiAR4
00000000                            	dc.b	(cfiAM1<<7)|cfiDR1, (cfiAM2<<7)|cfiDR2, (cfiAM3<<7)|cfiDR3, (cfiAM4<<7)|cfiDR4
00000000                            	dc.b	cfiSR1, cfiSR2, cfiSR3, cfiSR4
00000000                            	dc.b	(cfiSL1<<4)|cfiRR1, (cfiSL2<<4)|cfiRR2, (cfiSL3<<4)|cfiRR3, (cfiSL4<<4)|cfiRR4
00000000                            	dc.b	cfiSSG1, cfiSSG2, cfiSSG3, cfiSSG4
00000000                            	dc.b	(cfiFB<<3)|cfiALG
00000000                            	
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            	include	"include/macros/mega drive.asm"
00000000                            ; --------------------------------------------------------------
00000000                            ; Stop the Z80
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            Z80_STOP macro
00000000                            
00000000                            	move.w	#$100,Z80_BUS
00000000                            
00000000                            .WaitZ80Stop\@:
00000000                            	nop
00000000                            	nop
00000000                            	nop
00000000                            	nop
00000000                            	btst	#0,Z80_BUS
00000000                            	bne.s	.WaitZ80Stop\@
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Start the Z80
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            Z80_START macro
00000000                            
00000000                            	move.w	#0,Z80_BUS
00000000                            
00000000                            .WaitZ80Start\@:
00000000                            	nop
00000000                            	nop
00000000                            	nop
00000000                            	nop
00000000                            	btst	#0,Z80_BUS
00000000                            	beq.s	.WaitZ80Start\@
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; DMA copy
00000000                            ; --------------------------------------------------------------
00000000                            
00000000 =00000021                  VDP_VRAM	EQU	%100001
00000000 =0000002B                  VDP_CRAM	EQU	%101011
00000000 =00000025                  VDP_VSRAM	EQU	%100101
00000000 =0000000C                  VDP_READ	EQU	%001100
00000000 =00000007                  VDP_WRITE	EQU	%000111
00000000 =00000027                  VDP_DMA		EQU	%100111
00000000                            
00000000                            DMA_COPY macro src, dest, size, type
00000000                            
00000000                            	lea	VDP_CTRL,a0
00000000                            	move.w	#$8100,d0
00000000                            	move.b	vdp_reg_1,d0
00000000                            	ori.b	#$10,d0
00000000                            	move.w	d0,(a0)
00000000                            
00000000                            	move.w	#$9400|(((\size)>>9)&$FF),(a0)
00000000                            	move.w	#$9300|(((\size)>>1)&$FF),(a0)
00000000                            	move.w	#$9600|(((\src)>>9)&$FF),(a0)
00000000                            	move.w	#$9500|(((\src)>>1)&$FF),(a0)
00000000                            	move.w	#$9700|(((\src)>>17)&$7F),(a0)
00000000                            	move.w	#(((VDP_\type&VDP_DMA)&3)<<14)|((\dest)&$3FFF),(a0)
00000000                            	move.w	#(((VDP_\type&VDP_DMA)&$FC)<<2)|(((\dest)&$C000)>>14),dma_cmd_low
00000000                            
00000000                            	Z80_STOP
00000000                            	move.w	dma_cmd_low,(a0)
00000000                            	move.w	#$8100,d0
00000000                            	move.b	vdp_reg_1,d0
00000000                            	move.w	d0,(a0)
00000000                            	Z80_START
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Disable interrupts
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            DISABLE_INTS macros 
00000000                            	ori	#$700,sr
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Enable interrupts
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            ENABLE_INTS macros 
00000000                            	andi	#~$700,sr
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set carry flag
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            SET_CARRY macros 
00000000                            	ori	#1,sr
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Clear carry flag
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            CLEAR_CARRY macros 
00000000                            	andi	#~1,sr
00000000                            	
00000000                            ; --------------------------------------------------------------
00000000                            ; Bankswitch between SRAM and ROM (enable SRAM in the header!)
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            USE_SRAM macro
00000000                            
00000000                            	move.b  #1,($A130F1).l
00000000                            	endm
00000000                            
00000000                            USE_ROM macro
00000000                            		
00000000                            	move.b  #0,($A130F1).l
00000000                            	endm
00000000                            	
00000000                            ; --------------------------------------------------------------
00000000                            ; Align macro
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ; 	bound	- Size boundary
00000000                            ;	value	- Value to pad with
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            ALIGN macro bound, value
00000000                            
00000000                            	if narg=1
00000000                            		dcb.b	((\bound)-(*%(\bound)))%(\bound), 0
00000000                            	else
00000000                            		dcb.b	((\bound)-(*%(\bound)))%(\bound), \value
00000000                            	endif
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            	
00000000                            	include	"include/macros/set password.asm"
