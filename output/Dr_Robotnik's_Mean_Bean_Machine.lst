00000000                            ; --------------------------------------------------------------
00000000                            ; Set tempo
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	tempo	- Tempo
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cSetTempo macros tempo
00000000                            
00000000                            	dc.b	$FA, \tempo
00000000                            
00000000                            ; --------------------------------------------------------------
