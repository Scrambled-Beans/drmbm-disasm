00022418                            				
00022418 2020 2020 4465 7665 6C6F+  	dc.b	"    Developed for use onry with ntsc    "
00022440 2020 2020 2020 2020 2020+  	dc.b	"            genesis system.             "
00022468                            	even
00022468                            					
00022468                            Str_RegionLockPAL:
00022468                            	include "resources/text/Region/Wrong Region PAL.asm"
00022468                            									
00022468 2020 4465 7665 6C6F 7065+  	dc.b	"  Developed for use onry with pal and   "
00022490 2020 2020 6672 656E 6368+  	dc.b	"    french secam Mega Drive System.     "
