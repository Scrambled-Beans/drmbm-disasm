00000000                            ; --------------------------------------------------------------
00000000                            ; Store a pointer for the Z80
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Address to store
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            ZDW macros addr
00000000                            
00000000                            	dc.b	\addr&$FF, ((\addr>>8)&$7F)|$80
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set music/SFX type
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	 type	- Music/SFX type
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cType macros type
00000000                            
00000000                            	dc.b	\type
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set fade out timer
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	time	- Time it takes before it fades out
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cFadeOut macros time
00000000                            
00000000                            	dc.b	(\time)&$FF, (\time)>>8
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set tempo
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	tempo	- Tempo
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cTempo macros tempo
00000000                            
00000000                            	dc.b	\tempo
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Channel pointer
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Channel address
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cChannel macros addr
00000000                            
00000000                            	ZDW	\addr
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Store a note
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	note	- Note ID
00000000                            ;	length	- Note length (optional)
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cNote macro note, length
00000000                            
00000000                            	if (narg=1)
00000000                            		dc.b	\note
00000000                            	else
00000000                            		dc.b	(\note)|$80, \length
00000000                            	endif
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Main loop start
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cLoopStart macros
00000000                            
00000000                            	dc.b	$F8, $00
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Main loop end
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cLoopEnd macros
00000000                            
00000000                            	dc.b	$F8, $A1
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set volta loop position
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cVoltaLoop macros
00000000                            
00000000                            	dc.b	$F8, $20
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Volta section 1 start
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cVoltaSect1 macros
00000000                            
00000000                            	dc.b	$F8, $40
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Volta section 2 start
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cVoltaSect2 macros
00000000                            
00000000                            	dc.b	$F8, $60
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Volta section 3 start
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cVoltaSect3 macros
00000000                            
00000000                            	dc.b	$F8, $80
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Volta section end
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cVoltaSectEnd macros
00000000                            
00000000                            	dc.b	$F8, $A0
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Loop (with counter) start
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	count	- Loop count
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cLoopCnt macros count
00000000                            
00000000                            	dc.b	$F8, $C0|(\count)
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Loop (with counter) end
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cLoopCntEnd macros count
00000000                            
00000000                            	dc.b	$F8, $E0
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set note shift
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	dir	- Shift direction
00000000                            ;	detune	- Detune
00000000                            ;	trns	- Transposition
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cNoteShift macros dir, detune, trns
00000000                            
00000000                            	dc.b	$F9, ((\dir)<<7)|((\detune)<<4)|(\trns)
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set panning
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	pan	- Pan settings
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cPan macros pan
00000000                            
00000000                            	dc.b	$FA, \pan
