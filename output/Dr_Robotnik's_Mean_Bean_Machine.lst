00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Build Settings and Build Flags
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            	include	"build config.asm"											
00000000                            ; --------------------------------------------------------------
00000000                            ; Build Settings (Text Script)
00000000                            ; --------------------------------------------------------------
00000000                            
00000000 =00000001                  CompressArtMap=1			; 0 = Don't compress the Art and Mappings
00000000                            							; 1 =    Do compress the Art and Mappings
00000000                            				
00000000 =00000000                  NemesisCompress=0			; 0 = Accurate Nemesis Compression
00000000                            							; 1 = Improved Nemesis Compression
00000000                            
00000000 =00000000                  EnigmaCompress=0			; 0 = Don't compress the Engima mappings
00000000                            							; 1 =    Do compress the Engima mappings	
00000000                            							
00000000 =00000001                  KeepPrevBuild=1				; 0 = Don't keep a copy of the previous Build
00000000                            							; 1 =    Do keep a copy of the previous Build
00000000                            							
00000000 =00000002                  FileExtension=2				; The following File Extensions tell the user 
00000000                            							; that the ROM is in the raw binary format.
00000000                            							;
00000000                            							; Which one you use is down to preference.
00000000                            							;
00000000                            							; 		0 = .bin | Binary (recommended)
00000000                            							; 		1 = .md  | Sega Mega Drive (Japan or Europe)
00000000                            							; 		2 = .gen | Sega Genesis (North American)
00000000                            							; 		3 = .68K | Motorola 68000 Series (Used by Sega)
00000000                            							; 		4 = .SGD | Sega Development (Used by Sega)
00000000                            														
00000000                            ; --------------------------------------------------------------
00000000                            ; Build Flags (ROM)
00000000                            ; --------------------------------------------------------------
00000000                            							
00000000 =00000001                  ConsoleHeader:		equ 1	; 0 = Header says "SEGA MEGA DRIVE"
00000000                            							; 1 = Header says "SEGA GENESIS"
00000000                            							
00000000 =00000001                  RegionCode:			equ 1	; 0 = J - Japan
00000000                            							; 1 = U - USA
00000000                            							; 2 = E - Europe
00000000                            
00000000 =00000000                  EuropeFixes:		equ 0	; 0 = Don't include fixes from Europe version
00000000                            							; 1 =    Do include fixes from Europe version
00000000                            							
00000000 =00000000                  RegionLock:			equ 0   ; 0 = Only work on Sega Genesis Consoles (English/NTSC)
00000000                            							; 1 = Only work on Sega Mega Drive Consoles (English/PAL)
00000000                            							; 2 = Work on any Sega Genesis/Mega Drive Consoles
00000000                            							
00000000 =00000000                  BugFixes:			equ 0	; 0 = Keep bugs from Puyo Puyo (Arcade - Rev A) 
00000000                            							; 1 =  Fix bugs from Puyo Puyo (Arcade - Rev B) 
00000000                            							;
00000000                            							;   	Fix 1 - The AI won't lose its ability to manually 
00000000                            							;		        drop Beans if the other controller is
00000000                            							;				held to the left or right.
00000000                            							;
00000000                            							;		Fix 2 - Only select 28 letters instead of 29 letters
00000000                            							;				when pressing UP on the HIGH SCORES board.
00000000                            							
00000000                            ; --------------------------------------------------------------
00000000                            ; Build Flags (SRAM)
00000000                            ; --------------------------------------------------------------
00000000                            
00000000 =00000000                  EnableSRAM:			equ 0	; 0 = Disable SRAM
00000000                            							; 1 = Enable SRAM
00000000                            							
00000000 =00000003                  ReadWriteType:		equ 3	; 3 =     Odd Only - SRAM (recommended)
00000000                            							; 2 =    Even Only - SRAM
00000000                            							; 0 = Odd and Even - SRAM
00000000                            							; 1 = Serial EEPROMS (RAMs with 4-bit data bus, etc)
00000000                            														
00000000 =00000001                  DeviceType:			equ 1	; 1 = SRAM
00000000                            							; 2 = EEPROM	
00000000                            
00000000 =00000000                  SizeSRAM:			equ 0	; 0 =  8 KB ( 64 Kb)
00000000                            							; 1 = 32 KB (256 Kb)
00000000                            							
00000000                            ; --------------------------------------------------------------
00000000                            														
00000000                            ; --------------------------------------------------------------
00000000                            ; axm68k - More CPUs
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            	include	"tools/Macros - More CPUs.asm"
00000000                            ; ---------------------------------------------------------------------------
00000000                            ; Change CPU
00000000                            ; ---------------------------------------------------------------------------
00000000                            
00000000                            cpu:		macro
00000000                            		if strcmp("\1","z80")
00000000                            		pusho						; save previous options
00000000                            		cpu_mode:	= 1				; Z80
00000000                            		opt	an+					; 1234h style numbering
00000000                            		opt	ae-					; disable auto evens
00000000                            
00000000                            		else
00000000                            		if def(cpu_mode)
00000000                            		popo						; restore options
00000000                            		endc
00000000                            
00000000                            		cpu_mode:	= 0				; 68000 by default
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            ; ---------------------------------------------------------------------------
00000000                            ; AS compatibility
00000000                            ; ---------------------------------------------------------------------------
00000000                            
00000000                            phase:		macros
00000000                            		obj \1
00000000                            
00000000                            dephase:	macros
00000000                            		objend
00000000                            
00000000                            listing:	macro
00000000                            		if strcmp("\1","on")
00000000                            		list
00000000                            		else
00000000                            		nolist
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            binclude:	macros
00000000                            		incbin	\_
00000000                            
00000000                            ; ---------------------------------------------------------------------------
00000000                            ; Z80 instruction set
00000000                            ; ---------------------------------------------------------------------------
00000000                            
00000000                            getzreg:	macro						; convert register to numerical value
00000000                            		if strcmp("\1","a")
00000000                            		zreg: = 7
00000000                            		elseif strcmp("\1","b")
00000000                            		zreg: = 0
00000000                            		elseif strcmp("\1","c")
00000000                            		zreg: = 1
00000000                            		elseif strcmp("\1","d")
00000000                            		zreg: = 2
00000000                            		elseif strcmp("\1","e")
00000000                            		zreg: = 3
00000000                            		elseif strcmp("\1","h")
00000000                            		zreg: = 4
00000000                            		elseif strcmp("\1","l")
00000000                            		zreg: = 5
00000000                            		elseif strcmp("\1","(hl)")
00000000                            		zreg: = 6
00000000                            		else
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            getindex:	macro						; convert index register to register offset and value
00000000                            		if instr("\1","(ix")
00000000                            		ireg: = $dd
00000000                            		elseif instr("\1","(iy")
00000000                            		ireg: = $fd
00000000                            		else
00000000                            			fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000 =00000000                  ix: =		0						; allows (ix+n) to be parsed as n
00000000 =00000000                  iy: =		0
00000000                            
00000000                            adc:		macro
00000000                            		local num
00000000                            		if strcmp("\1","hl")
00000000                            			if strcmp("\2","bc")
00000000                            			dc.w $ed4a
00000000                            			elseif strcmp("\2","de")
00000000                            			dc.w $ed5a
00000000                            			elseif strcmp("\2","hl")
00000000                            			dc.w $ed6a
00000000                            			elseif strcmp("\2","sp")
00000000                            			dc.w $ed7a
00000000                            			else
00000000                            			fail
00000000                            			endc
00000000                            			mexit
00000000                            		endc
00000000                            
00000000                            		; "adc a, x" or "adc x"
00000000                            		if narg=2 & strcmp("\1","a")
00000000                            			shift					; ignore a
00000000                            		endc
00000000                            
00000000                            		if (narg=1) | (narg=2)
00000000                            			if instr("a b c d e h l (hl) ","\1\ ")
00000000                            			getzreg	\1
00000000                            			dc.b $88+zreg
00000000                            			elseif strcmp("\1","ixh")|strcmp("\1","ixu")
00000000                            			dc.w $dd8c
00000000                            			elseif strcmp("\1","ixl")
00000000                            			dc.w $dd8d
00000000                            			elseif strcmp("\1","iyh")|strcmp("\1","iyu")
00000000                            			dc.w $fd8c
00000000                            			elseif strcmp("\1","iyl")
00000000                            			dc.w $fd8d
00000000                            			elseif instr("\1","(i")			; adc (ix+n)
00000000                            				num: equ \1
00000000                            				getindex \1
00000000                            				dc.b ireg, $8e, num
00000000                            			else					; adc n
00000000                            			num: equ \1
00000000                            			dc.b $ce, num
00000000                            			endc
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            bit:		macro
00000000                            		local num, num2
00000000                            		num: equ \1
00000000                            		if instr("a b c d e h l (hl) ","\2\ ")
00000000                            		getzreg	\2
00000000                            		dc.b $cb, $40+(num*8)+zreg
00000000                            		elseif instr("\2","(i")				; bit n,(ix+n)
00000000                            			num2: equ \2
00000000                            			getindex \2
00000000                            			dc.b ireg, $cb, num2, $46+(num*8)
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            call:		macro
00000000                            		local num
00000000                            		if narg=1					; call n
00000000                            		num: equ \1
00000000                            		dc.b $cd
00000000                            		elseif narg=2					; call x, n
00000000                            			num: equ \2
00000000                            			if strcmp("\1","nz")
00000000                            			dc.b $c4
00000000                            			elseif strcmp("\1","z")
00000000                            			dc.b $cc
00000000                            			elseif strcmp("\1","nc")
00000000                            			dc.b $d4
00000000                            			elseif strcmp("\1","c")
00000000                            			dc.b $dc
00000000                            			elseif strcmp("\1","po")
00000000                            			dc.b $e4
00000000                            			elseif strcmp("\1","pe")
00000000                            			dc.b $ec
00000000                            			elseif strcmp("\1","p")
00000000                            			dc.b $f4
00000000                            			elseif strcmp("\1","m")
00000000                            			dc.b $fc
00000000                            			else
00000000                            				fail
00000000                            			endc
00000000                            
00000000                            			shift
00000000                            		else
00000000                            			fail
00000000                            		endc
00000000                            
00000000                            		dc.b num&$FF, num>>8
00000000                            		endm
00000000                            
00000000                            ccf:		macros
00000000                            		dc.b $3f
00000000                            
00000000                            
00000000                            cp:		macro
00000000                            		local num
00000000                            		if instr("a b c d e h l (hl) ","\1\ ")
00000000                            		getzreg	\1
00000000                            		dc.b $b8+zreg
00000000                            		elseif strcmp("\1","ixh")|strcmp("\1","ixu")
00000000                            		dc.w $ddbc
00000000                            		elseif strcmp("\1","ixl")
00000000                            		dc.w $ddbd
00000000                            		elseif strcmp("\1","iyh")|strcmp("\1","iyu")
00000000                            		dc.w $fdbc
00000000                            		elseif strcmp("\1","iyl")
00000000                            		dc.w $fdbd
00000000                            		elseif instr("\1","(i")				; cp (ix+n)
00000000                            			num: equ \1
00000000                            			getindex \1
00000000                            			dc.b ireg, $be, num
00000000                            		else						; cp n
00000000                            		num: equ \1
00000000                            		dc.b $fe, num
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            cpd:		macros
00000000                            		dc.w $eda9
00000000                            
00000000                            
00000000                            cpdr:		macros
00000000                            		dc.w $edb9
00000000                            
00000000                            
00000000                            cpi:		macros
00000000                            		dc.w $eda1
00000000                            
00000000                            
00000000                            cpir:		macros
00000000                            		dc.w $edb1
00000000                            
00000000                            
00000000                            cpl:		macros
00000000                            		dc.b $2f
00000000                            
00000000                            
00000000                            daa:		macros
00000000                            		dc.b $27
00000000                            
00000000                            
00000000                            dec:		macro
00000000                            		local num
00000000                            		if instr("a b c d e h l (hl) ","\1\ ")
00000000                            		getzreg	\1
00000000                            		dc.b $5+(zreg*8)
00000000                            		elseif strcmp("\1","ixh")|strcmp("\1","ixu")
00000000                            		dc.w $dd25
00000000                            		elseif strcmp("\1","ixl")
00000000                            		dc.w $dd2d
00000000                            		elseif strcmp("\1","iyh")|strcmp("\1","iyu")
00000000                            		dc.w $fd25
00000000                            		elseif strcmp("\1","iyl")
00000000                            		dc.w $fd2d
00000000                            		elseif strcmp("\1","bc")
00000000                            		dc.b $b
00000000                            		elseif strcmp("\1","de")
00000000                            		dc.b $1b
00000000                            		elseif strcmp("\1","hl")
00000000                            		dc.b $2b
00000000                            		elseif strcmp("\1","ix")
00000000                            		dc.w $dd2b
00000000                            		elseif strcmp("\1","iy")
00000000                            		dc.w $fd2b
00000000                            		elseif strcmp("\1","sp")
00000000                            		dc.b $3b
00000000                            		elseif instr("\1","(i")				; dec (ix+n)
00000000                            			num: equ \1
00000000                            			getindex \1
00000000                            			dc.b ireg, $35, num
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            di:		macros
00000000                            		dc.b $f3
00000000                            
00000000                            
00000000                            djnz:		macro
00000000                            		local num
00000000                            		num: equ \1
00000000                            		dc.b $10, num-*-2
00000000                            		endm
00000000                            
00000000                            
00000000                            ei:		macros
00000000                            		dc.b $fb
00000000                            
00000000                            
00000000                            ex:		macro
00000000                            		if strcmp("\_","af,af")				; ex af,af'
00000000                            		dc.b 8
00000000                            		elseif strcmp("\_","(sp),hl")
00000000                            		dc.b $e3
00000000                            		elseif strcmp("\_","(sp),ix")
00000000                            		dc.w $dde3
00000000                            		elseif strcmp("\_","(sp),iy")
00000000                            		dc.w $fde3
00000000                            		elseif strcmp("\_","de,hl")
00000000                            		dc.b $eb
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            exx:		macros
00000000                            		dc.b $d9
00000000                            
00000000                            
00000000                            halt:		macros
00000000                            		dc.b $76
00000000                            
00000000                            
00000000                            im:		macro
00000000                            		if \1=0
00000000                            		dc.w $ed46
00000000                            		elseif \1=1
00000000                            		dc.w $ed56
00000000                            		elseif \1=2
00000000                            		dc.w $ed5e
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            in:		macro
00000000                            		local num
00000000                            		if strcmp("\1","a")
00000000                            			if strcmp("\2","(c)")
00000000                            			dc.w $ed78
00000000                            			else					; in a,n
00000000                            			num: equ \2
00000000                            			dc.b $db, num
00000000                            			endc
00000000                            		elseif instr("b c d e h l ","\1\ ")&strcmp("\2","(c)")
00000000                            		getzreg	\1
00000000                            		dc.w $ed40+(zreg*8)
00000000                            		elseif strcmp("\1","(c)")
00000000                            		dc.w $ed70
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            inc:		macro
00000000                            		local num
00000000                            		if instr("a b c d e h l (hl) ","\1\ ")
00000000                            		getzreg	\1
00000000                            		dc.b $4+(zreg*8)
00000000                            		elseif strcmp("\1","ixh")|strcmp("\1","ixu")
00000000                            		dc.w $dd24
00000000                            		elseif strcmp("\1","ixl")
00000000                            		dc.w $dd2c
00000000                            		elseif strcmp("\1","iyh")|strcmp("\1","iyu")
00000000                            		dc.w $fd24
00000000                            		elseif strcmp("\1","iyl")
00000000                            		dc.w $fd2c
00000000                            		elseif strcmp("\1","bc")
00000000                            		dc.b $3
00000000                            		elseif strcmp("\1","de")
00000000                            		dc.b $13
00000000                            		elseif strcmp("\1","hl")
00000000                            		dc.b $23
00000000                            		elseif strcmp("\1","ix")
00000000                            		dc.w $dd23
00000000                            		elseif strcmp("\1","iy")
00000000                            		dc.w $fd23
00000000                            		elseif strcmp("\1","sp")
00000000                            		dc.b $33
00000000                            		elseif instr("\1","(i")				; inc (ix+n)
00000000                            			num: equ \1
00000000                            			getindex \1
00000000                            			dc.b ireg, $34, num
00000000                            		else
00000000                            		fail
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            ind:		macros
00000000                            		dc.w $edaa
00000000                            
00000000                            
00000000                            indr:		macros
00000000                            		dc.w $edba
00000000                            
00000000                            
00000000                            ini:		macros
00000000                            		dc.w $eda2
00000000                            
00000000                            
00000000                            inir:		macros
00000000                            		dc.w $edb2
00000000                            
00000000                            
00000000                            jp:		macro
00000000                            		local num
00000000                            		if strcmp("\1","(hl)")
00000000                            		dc.b $e9
00000000                            		elseif strcmp("\1","(ix)")
00000000                            		dc.w $dde9
00000000                            		elseif strcmp("\1","(iy)")
00000000                            		dc.w $fde9
00000000                            		else
00000000                            			if strcmp("\1","nz")
00000000                            			num: equ \2
00000000                            			dc.b $c2
00000000                            			elseif strcmp("\1","z")
00000000                            			num: equ \2
00000000                            			dc.b $ca
00000000                            			elseif strcmp("\1","nc")
00000000                            			num: equ \2
00000000                            			dc.b $d2
00000000                            			elseif strcmp("\1","c")
00000000                            			num: equ \2
00000000                            			dc.b $da
00000000                            			elseif strcmp("\1","po")
00000000                            			num: equ \2
00000000                            			dc.b $e2
00000000                            			elseif strcmp("\1","pe")
00000000                            			num: equ \2
00000000                            			dc.b $ea
00000000                            			elseif strcmp("\1","p")
00000000                            			num: equ \2
00000000                            			dc.b $f2
00000000                            			elseif strcmp("\1","m")
00000000                            			num: equ \2
00000000                            			dc.b $fa
00000000                            			else					; jp n
00000000                            			num: equ \1
00000000                            			dc.b $c3
00000000                            			endc
00000000                            			if narg=2
00000000                            			shift
00000000                            			endc
00000000                            			dc.b num&$FF, num>>8
00000000                            		endc
00000000                            		endm
00000000                            
00000000                            
00000000                            jr:		macro
00000000                            		local num
00000000                            		if strcmp("\1","nz")
00000000                            		num: equ \2
00000000                            		dc.b $20
00000000                            		elseif strcmp("\1","z")
00000000                            		num: equ \2
00000000                            		dc.b $28
00000000                            		elseif strcmp("\1","nc")
00000000                            		num: equ \2
00000000                            		dc.b $30
00000000                            		elseif strcmp("\1","c")
00000000                            		num: equ \2
00000000                            		dc.b $38
00000000                            		else						; jr n
00000000                            		num: equ \1
00000000                            		dc.b $18
00000000                            		endc
00000000                            		if narg=2
00000000                            		shift
00000000                            		endc
00000000                            		dc.b num-*-1
00000000                            		;if ((num-*)>=-$80)&((num-*)<=$7f)
00000000                            		;fail
00000000                            		;endc
00000000                            		endm
00000000                            
00000000                            
00000000                            ld:		macro
00000000                            		local num, num2
00000000                            		if strcmp("\1","a")
00000000                            			if instr("a b c d e h l (hl) ","\2\ ")
00000000                            			getzreg	\2
00000000                            			dc.b $78+zreg
00000000                            			elseif strcmp("\2","i")
00000000                            			dc.w $ed57
00000000                            			elseif strcmp("\2","r")
00000000                            			dc.w $ed5f
00000000                            			elseif strcmp("\2","ixh")|strcmp("\2","ixu")
00000000                            			dc.w $dd7c
00000000                            			elseif strcmp("\2","ixl")
00000000                            			dc.w $dd7d
00000000                            			elseif strcmp("\2","iyh")|strcmp("\2","iyu")
00000000                            			dc.w $fd7c
00000000                            			elseif strcmp("\2","iyl")
00000000                            			dc.w $fd7d
00000000                            			elseif strcmp("\2","(bc)")
00000000                            			dc.b $0a
00000000                            			elseif strcmp("\2","(de)")
00000000                            			dc.b $1a
00000000                            			elseif instr("\2","(i")			; ld a,(ix+n)
00000000                            				num: equ \2
00000000                            				getindex \2
00000000                            				dc.b ireg, $7e, num
00000000                            			else
00000000                            				num: equ \2
00000000                            				tmp_len: = strlen("\2")
00000000                            				tmp_fc:	substr	1,1,"\2"
00000000                            				tmp_lc:	substr	tmp_len,tmp_len,"\2"
00000000                            				if strcmp("\tmp_fc","(") & strcmp("\tmp_lc",")") ; ld a,(n)
00000000                            				dc.b $3a, num&$ff, num>>8
00000000                            				else				; ld a,n
00000000                            				dc.b $3e, num
00000000                            				endc
00000000                            			endc
00000000                            		elseif strcmp("\1","b")
00000000                            			if instr("a b c d e h l (hl) ","\2\ ")
00000000                            			getzreg	\2
00000000                            			dc.b $40+zreg
00000000                            			elseif strcmp("\2","ixh")|strcmp("\2","ixu")
00000000                            			dc.w $dd44
00000000                            			elseif strcmp("\2","ixl")
00000000                            			dc.w $dd45
00000000                            			elseif strcmp("\2","iyh")|strcmp("\2","iyu")
00000000                            			dc.w $fd44
00000000                            			elseif strcmp("\2","iyl")
00000000                            			dc.w $fd45
00000000                            			elseif instr("\2","(i")			; ld b,(ix+n)
00000000                            				num: equ \2
