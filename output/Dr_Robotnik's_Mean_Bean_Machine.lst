00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	vib	- Vibrato ID
00000000                            ;	delay	- Vibrato delay
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cVibrato macros vib, delay
00000000                            
00000000                            	dc.b	$FB, ((\vib)<<4)|(\delay)
00000000                            
