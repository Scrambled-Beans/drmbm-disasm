000224B8                            
000224B8                            ; =============== S U B	R O U T	I N E =======================================
000224B8                            
000224B8                            GetRegion:
000224B8 1039 00A1 0001             	move.b	CONSOLE_VER,d0		; Get the region of the console
000224BE                            								; 76543210
000224BE                            								; RME VVVV
000224BE                            								; R = Region : 0 = JPN  | 1 = ENG
000224BE                            								; M = TV Mode: 0 = NTSC | 0 = PAL
000224BE                            								; VVVV = Version
000224BE                            					
000224BE                            	andi.b	#$C0,d0				; Removes bits 5-0 from the console byte,
000224C2                            								; leaving us with the the Region and TV Mode
000224C2                            	
000224C2                            	if RegionLock=0		; English/NTSC Console
000224C2                            	subi.b	#$80,d0					; Takes away hex 80 from console byte
000224C6                            									; 80 = 10000000 = ENG and NTSC
000224C6                            									
000224C6                            	else 				; English/PAL Console
000224C6                            	subi.b	#$C0,d0					; Takes away hex C0 from console byte
000224C6                            									; C0 = 11000000 = ENG and NTSC		
000224C6                            
000224C6                            	endc
000224C6                            									
000224C6                            	nop
000224C8                            	nop
000224CA                            	nop
000224CC                            	nop
000224CE 13C0 00FF 0A3A             	move.b	d0,(bytecode_flag).l	; Moves this byte into bytecode_flag
000224D4                            									; If 0, then the flag will be clear (the correct region)
000224D4                            									; If not 0, then the flag will be clear (the wrong region) 
000224D4                            												
000224D4 4E75                       	rts								; Return to Start
000224D6                            					
000224D6                            ; =============== S U B	R O U T	I N E =======================================
000224D6                            
000224D6                            RegionLockout:
000224D6                            	if RegionLock=0		; English/NTSC Console
000224D6 45F9 0002 2418             	lea	(Str_RegionLockNTSC).l,a2
000224DC 103C 0080                  	move.b	#$80,d0
000224E0 0C00 0080                  	cmpi.b	#$80,d0
000224E4 67FE                       	beq.s	.print
000224E6 45F9 0002 2468             	lea	(Str_RegionLockPAL).l,a2
000224EC                            	
000224EC                            	else				; English/PAL Console
000224EC                            	lea	(Str_RegionLockNTSC).l,a2
000224EC                            	move.b	#$C0,d0
000224EC                            	cmpi.b	#$80,d0
000224EC                            	beq.s	.print
000224EC                            	lea	(Str_RegionLockPAL).l,a2
000224EC                            	
000224EC                            	endc
000224EC                            
000224EC                            .print:
000224EC 3A3C C500                  	move.w	#$C500,d5
000224F0 7001                       	moveq	#1,d0
000224F2 7227                       	moveq	#$27,d1
000224F4 3C3C 0500                  	move.w	#$500,d6
000224F8 4EB9 0000 0000             	jsr	(RegionLock_Print).l
000224FE 43F9 0000 0000             	lea	(ActRegionLockout).l,a1
00022504 4EF9 0000 363A             	jmp	(FindActorSlot).l
