00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            Set_Password macro bean1, bean2, bean3, bean4
00000000                            
00000000                            	dc.w	$0000+(bean1<<12)+(bean2<<8)+(bean3<<4)+(bean4<<0)
00000000                            	
00000000                            	endm
