00000000                            	; Macros
00000000                            	
00000000                            	include	"include/macros/bytecodes.asm"
00000000                            ; --------------------------------------------------------------
00000000                            ; Disable bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BDISABLE macros
00000000                            
00000000                            	dc.w	0
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Frame done bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BFRMEND macros
00000000                            
00000000                            	dc.w	1
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Delay bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	delay	- Delay time
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BDELAY macros delay
00000000                            
00000000                            	dc.w	2, \delay
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Wait for palette fade bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BFADEW macros
00000000                            
00000000                            	dc.w	3
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Write to memory bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Address to write to
00000000                            ;	val	- Value to write
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BWRITE macro addr, val
00000000                            
00000000                            	dc.w	4
00000000                            	dc.l	\addr
00000000                            	dc.w	\val
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Run code bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Address to run code at
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BRUN macro addr
00000000                            
00000000                            	dc.w	5
00000000                            	dc.l	\addr
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Jump bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Address to jump to
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BJMP macro addr
00000000                            
00000000                            	dc.w	6
00000000                            	dc.l	\addr
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Jump if flag clear bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Address to jump to
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BJCLR macro addr
00000000                            
00000000                            	dc.w	7
00000000                            	dc.l	\addr
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Jump if flag set bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	addr	- Address to jump to
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BJSET macro addr
00000000                            
00000000                            	dc.w	8
00000000                            	dc.l	\addr
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Jump with table bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            
00000000 =00000000                  tbl_id = 0
00000000                            
00000000                            BJTBL macro
00000000                            
00000000                            tbl_id = tbl_id+1
00000000                            	dc.w	9
00000000                            	dc.w	(BCJMPTBL\#tbl_id\_END-BCJMPTBL\#tbl_id\)/4
00000000                            
00000000                            BCJMPTBL\#tbl_id\:
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Jump table end marker
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BJTBLE macro
00000000                            
00000000                            BCJMPTBL\#tbl_id\_End:
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Set VDP registers bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	set	- VDP register set ID
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BVDP macros set
00000000                            
00000000                            	dc.w	$A, \set
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Puyo decompression bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	vram	- VRAM address to decompress to
00000000                            ;	art	- Pointer to compressed art
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BPUYO macro vram, art
00000000                            
00000000                            	dc.w	$B, \vram
00000000                            	dc.l	\art
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Plame command list queue bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	list	- Plane command list ID
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BPCMD macros list
00000000                            
00000000                            	dc.w	$C, \list
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Load palette bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	pal	- Pointer to palette
00000000                            ;	line	- Palette line to load to
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BPAL macros pal, line
00000000                            
00000000                            	dc.w	$D, ((((\pal)-Palettes)&$1FFF)<<3)|((\line)&3)
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Fade to palette bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	pal	- Pointer to palette
00000000                            ;	line	- Palette line to load to
00000000                            ;	speed	- Fade speed
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BFADE macros pal, line, speed
00000000                            
00000000                            	dc.w	$E, ((((\pal)-Palettes)&$1FFF)<<3)|((\line)&3), (\speed)<<8
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Play sound bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	snd	- Sound ID
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BSND macros snd
00000000                            
00000000                            	dc.w	$F, \snd
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Play sound (and check PCM sample) bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	snd	- Sound ID
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BSNDP macros snd
00000000                            
00000000                            	dc.w	$10, \snd
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Fade out sound bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BSFADE macros
00000000                            
00000000                            	dc.w	$11
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Stop sound sound bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BSSTOP macros
00000000                            
00000000                            	dc.w	$12
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Play sound (and check PCM sample) bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	snd	- Sound ID
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BSNDP2 macros
00000000                            
00000000                            	dc.w	$13, \snd
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Nemesis decompression bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	vram	- VRAM address to decompress to
00000000                            ;	art	- Pointer to compressed art
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BNEM macro vram, art
00000000                            
00000000                            	dc.w	$14, \vram
00000000                            	dc.l	\art
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Fade to palette (checks intro scenes) bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	pal	- Pointer to palette
00000000                            ;	pal2	- Pointer to alternate palette
00000000                            ;	line	- Palette line to load to
00000000                            ;	speed	- Fade speed
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BFADEI macros pal, pal2, line, speed
00000000                            
00000000                            	dc.w	$15, ((((\pal)-Palettes)&$1FFF)<<3)|((\line)&3), 		((\speed)<<8)|((((\pal2)-Palettes)>>5)&$FF)
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Puyo decompression (checks intro scenes) bytecode instruction
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	vram	- VRAM address to decompress to
00000000                            ;	art	- Pointer to compressed art
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            BPUYOI macro vram, art
00000000                            
00000000                            	dc.w	$16, \vram
00000000                            	dc.l	\art
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
