00000000                            ; --------------------------------------------------------------
00000000                            
00000000 =00000000                  cfiCur	= 0
00000000                            
00000000                            cfiName macro name
00000000                            
00000000                            \name\	EQU	cfiCur
00000000                            cfiCur	=	cfiCur+1
00000000                            
00000000                            	endm
