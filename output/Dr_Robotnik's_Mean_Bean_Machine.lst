00000000                            ; --------------------------------------------------------------
00000000                            	
00000000                            	include	"include/macros/text - checksum.asm"
00000000                            ; --------------------------------------------------------------
00000000                            ; Checksum text data
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	text	- Text to store
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            CHECKSUM_TEXT macro text
00000000                            
00000000                            escape = 0
00000000                            i = 0
00000000                            	while i<strlen(\text)
00000000                            c substr 1+i,1+i,\text
00000000                            	if escape=0
00000000                            		; Escape character
00000000                            		if "\c"="%"
00000000                            escape = 1
00000000                            		; Space
00000000                            		elseif "\c"=" "
00000000                            			dc.b	$00
00000000                            			
00000000                            		; .
00000000                            		elseif ("\c"=".")
00000000                            			dc.b	$25			
00000000                            			
00000000                            		; ,
00000000                            		elseif ("\c"=",")
00000000                            			dc.b	$26			
00000000                            			
00000000                            		; /
00000000                            		elseif ("\c"="/")
00000000                            			dc.b	$27	
00000000                            
00000000                            		; :
00000000                            		elseif ("\c"=":")
00000000                            			dc.b	$28					
00000000                            			
00000000                            		; #
00000000                            		elseif ("\c"="#")
00000000                            			dc.b	$29
00000000                            			
00000000                            		; (
00000000                            		elseif ("\c"="(")
00000000                            			dc.b	$2A
00000000                            						
00000000                            		; )
00000000                            		elseif ("\c"=")")
00000000                            			dc.b	$2B
00000000                            			
00000000                            		; OFF
00000000                            		elseif ("\c"="@")
00000000                            			dc.w	$2C2D
00000000                            						
00000000                            		; -
00000000                            		elseif ("\c"="-")
00000000                            			dc.b	$2E
00000000                            		
00000000                            		; ~
00000000                            		elseif ("\c"="~")
00000000                            			dc.b	$2F
00000000                            
00000000                            		; >
00000000                            		elseif ("\c"=">")
00000000                            			dc.b	$30
00000000                            
00000000                            		; <
00000000                            		elseif ("\c"="<")
00000000                            			dc.b	$31
00000000                            
00000000                            		; ?
00000000                            		elseif ("\c"="?")
00000000                            			dc.b	$32
00000000                            
00000000                            		; !
00000000                            		elseif ("\c"="!")
00000000                            			dc.b	$3A
00000000                            			
00000000                            		; 0-9
00000000                            		elseif ("\c">="0")&("\c"<="9")
00000000                            			dc.b	("\c"-$2F)
00000000                            			
00000000                            		; A-Z
00000000                            		elseif ("\c">="A")&("\c"<="Z")
00000000                            			dc.b	("\c"-$40)+(10)			
00000000                            		
00000000                            		endif
00000000                            	else
00000000                            		; Custom character
00000000                            		if "\c"="c"
00000000                            			dc.b	$FE
00000000                            		; Invalid
00000000                            		else
00000000                            			inform 2,"Invalid escape character '%s'", "\c"
00000000                            		endif
00000000                            escape = 0
00000000                            	endif
00000000                            i = i+1
00000000                            	endw
00000000                            	
00000000                            	dc.b	$FF
00000000                            	even
00000000                            
00000000                            	endm
00000000                            	include	"include/macros/text - stage.asm"
00000000                            ; --------------------------------------------------------------
00000000                            ; Stage text data
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	font	- 0 for large font, 1 for small font
00000000                            ;	text	- Text to store
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            STAGE_TEXT macro font, text
00000000                            
00000000                            foff = 0
00000000                            	if (\font)<>0
00000000                            foff = $6A
00000000                            	endif
00000000                            
00000000                            escape = 0
00000000                            i = 0
00000000                            	while i<strlen(\text)
00000000                            c substr 1+i,1+i,\text
00000000                            	if escape=0
00000000                            		; Escape character
00000000                            		if "\c"="%"
00000000                            escape = 1
00000000                            		; Space
00000000                            		elseif ("\c"=" ")
00000000                            			dc.b	$00
00000000                            			
00000000                            		; ? (small font)
00000000                            		elseif ("\c"="?")&((\font)<>0)
00000000                            			dc.b	$B4
00000000                            			
00000000                            		; 0-9
00000000                            		elseif ("\c">="0")&("\c"<="9")
00000000                            			dc.b	("\c"-$2F)*2+foff
00000000                            			
00000000                            		; A-Z
00000000                            		elseif ("\c">="A")&("\c"<="Z")
00000000                            			dc.b	("\c"-$40)*2+(10*2)+foff
00000000                            			
00000000                            		; Small "x" (large font)
00000000                            		elseif ("\c"="x")&((\font)=0)
00000000                            			dc.b	$4A
00000000                            
00000000                            			
00000000                            		endif
00000000                            	else
00000000                            		; Custom character
00000000                            		if "\c"="c"
00000000                            			dc.b	$FE
00000000                            		; Invalid
00000000                            		else
00000000                            			inform 2,"Invalid escape character '%s'", "\c"
00000000                            		endif
00000000                            escape = 0
00000000                            	endif
00000000                            i = i+1
00000000                            	endw
00000000                            	
00000000                            	dc.b	$FF
00000000                            	even
00000000                            
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Print stage text at location
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	font	- 0 for large font, 1 for small font
00000000                            ;	loc	- VRAM location to store text
00000000                            ;		  If >= $C000, it's used as an absolute address,
00000000                            ;		  otherwise, it's treated as relative to a
00000000                            ;		  player's puyo field
00000000                            ;	base	- Base VRAM address for font
00000000                            ;	text	- Text to store
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            STAGE_TEXT_LOC macro font, loc, base, text
00000000                            
00000000                            	if (\loc)<$C000
00000000                            		dc.w	0, \loc, \base
00000000                            	else
00000000                            		dc.w	\loc, \base
00000000                            	endif
00000000                            
00000000                            	STAGE_TEXT \font, \text
00000000                            	
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            	include	"include/macros/text - high scores.asm"
00000000                            ; --------------------------------------------------------------
00000000                            ; Text - High Scores
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            TEXT_SCORE macro text, score, block
00000000                            
00000000                            	; Letters
00000000                            
00000000                            i = 0
00000000                            
00000000                            	while i<strlen(\text)
00000000                            	
00000000                            c substr 1+i,1+i,\text
00000000                            
00000000                            	; Space
00000000                            		if "\c"=" "
00000000                            		dc.b	$00
00000000                            			
00000000                            	; .
00000000                            		elseif "\c"="."
00000000                            		dc.b	$1B
00000000                            		
00000000                            	; .
00000000                            		elseif "\c"="#"
00000000                            		dc.b	$FF
00000000                            			
00000000                            	; A-Z
00000000                            		elseif ("\c">="A")&("\c"<="Z")
00000000                            		dc.b	("\c"-$40)	
00000000                            			
00000000                            		else
00000000                            		dc.b	$00
00000000                            		
00000000                            	endif
00000000                            		
00000000                            i = i+1
00000000                            	endw
00000000                            	
00000000                            	dc.b 	$FF			; 
00000000                            	dc.l	score		; Score
00000000                            	dc.w 	block		; Block
00000000                            	dc.l	0
00000000                            
00000000                            	endm
00000000                            	
00000000                            ; --------------------------------------------------------------
00000000                            	include	"include/macros/text - name.asm"
00000000                            ; --------------------------------------------------------------
00000000                            ; Name text data
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	font	- 0 for large font, 1 for small font
00000000                            ;	text	- Text to store
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            NAME_TEXT macro font, text
00000000                            
00000000                            foff = 0
00000000                            	if (\font)<>0
00000000                            foff = $6A
00000000                            	endif
00000000                            
00000000                            escape = 0
00000000                            i = 0
00000000                            	while i<strlen(\text)
00000000                            c substr 1+i,1+i,\text
00000000                            	if escape=0
00000000                            		; Escape character
00000000                            		if "\c"="%"
00000000                            escape = 1
00000000                            		; Space
00000000                            		elseif ("\c"=" ")
00000000                            			dc.b	$00
00000000                            			
00000000                            		; ? (small font)
00000000                            		elseif ("\c"="?")&((\font)<>0)
00000000                            			dc.b	$B4
00000000                            			
00000000                            		; 0-9
00000000                            		elseif ("\c">="0")&("\c"<="9")
00000000                            			dc.b	("\c"-$2F)*2+foff
00000000                            			
00000000                            		; A-Z
00000000                            		elseif ("\c">="A")&("\c"<="Z")
00000000                            			dc.b	("\c"-$40)*2+(10*2)+foff
00000000                            			
00000000                            		; Small "x" (large font)
00000000                            		elseif ("\c"="x")&((\font)=0)
00000000                            			dc.b	$4A
00000000                            
00000000                            			
00000000                            		endif
00000000                            	else
00000000                            		; Custom character
00000000                            		if "\c"="c"
00000000                            			dc.b	$FE
00000000                            		; Invalid
00000000                            		else
00000000                            			inform 2,"Invalid escape character '%s'", "\c"
00000000                            		endif
00000000                            escape = 0
00000000                            	endif
00000000                            i = i+1
00000000                            	endw
00000000                            	
00000000                            	endm
00000000                            
00000000                            ; --------------------------------------------------------------
00000000                            ; Print stage text at location
00000000                            ; --------------------------------------------------------------
00000000                            ; PARAMETERS:
00000000                            ;	font	- 0 for large font, 1 for small font
00000000                            ;	loc	- VRAM location to store text
00000000                            ;		  If >= $C000, it's used as an absolute address,
00000000                            ;		  otherwise, it's treated as relative to a
00000000                            ;		  player's puyo field
00000000                            ;	base	- Base VRAM address for font
00000000                            ;	text	- Text to store
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            NAME_TEXT_LOC macro font, loc, base, text
00000000                            
00000000                            	if (\loc)<$C000
00000000                            		dc.w	0, \loc, \base
00000000                            	else
00000000                            		dc.w	\loc, \base
00000000                            	endif
00000000                            
00000000                            	NAME_TEXT \font, \text
00000000                            	
00000000                            	endm
00000000                            
