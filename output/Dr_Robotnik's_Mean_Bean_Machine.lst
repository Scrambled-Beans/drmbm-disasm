00000000                            ;	op3	- Operator 3 value
00000000                            ;	op4	- Operator 4 value
00000000                            ; --------------------------------------------------------------
00000000                            
00000000                            cfiMultiple macro op1, op2, op3, op4
00000000                            
00000000                            cfiMULT1	= op1
00000000                            cfiMULT2	= op2
00000000                            cfiMULT3	= op3
00000000                            cfiMULT4	= op4
